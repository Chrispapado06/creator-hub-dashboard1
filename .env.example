# ── Client (Vite — shipped to the browser, must be public-safe) ──────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# ── Task handoff pipeline — server-side only (NEVER prefix with VITE_) ────────
# A Discord channel "incoming webhook" URL. Set in Vercel → Project → Settings
# → Environment Variables (and in a local .env for `vercel dev`). The browser
# never sees this; the /api/discord-notify function forwards pings to it.
DISCORD_TASK_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY
# Optional shared secret. If set, the client must send it as x-task-notify-secret
# (leave unset to allow same-origin calls without it).
DISCORD_TASK_NOTIFY_SECRET=

# ── Task pipeline — Discord BOT (personal DMs + the daily task digest) ───────
# Create a bot at discord.com/developers → New Application → Bot → copy the
# token; invite it to your server. The bot DMs each person their handoff pings
# and a daily task digest (api/discord-dm.js + api/discord-digest.js). The bot
# must share a server with each recipient and they must allow DMs.
DISCORD_BOT_TOKEN=
# Random string. Secures the daily-digest cron — Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>` on the scheduled run (vercel.json crons).
CRON_SECRET=

# ── Task handoff pipeline — WhatsApp via Twilio, server-side only ────────────
# Twilio's WhatsApp Sandbox needs no Meta business verification / template
# approval — recipients send the sandbox "join <code>" once. From the Twilio
# Console dashboard: Account SID + Auth Token. The sandbox sender is usually
# whatsapp:+14155238886 (Messaging → Try it out → WhatsApp Sandbox).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
