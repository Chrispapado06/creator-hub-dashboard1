{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "shift-downtime-monitor/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "node monitor.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
